# Public site environment variables.
# Copy this file to `.env.local` and fill in the values.
# Vars prefixed with NEXT_PUBLIC_ are inlined into the client bundle at build time.

# ---------------------------------------------------------------------------
# Supabase (existing) — auth + bookings storage
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# Wellness Backend — POST destination for booking enquiries
# ---------------------------------------------------------------------------
# The Express + MongoDB service at MyDawaiWala10/WellnessBackend. Every
# booking-form submission posts to `${URL}/api/appointments/public` so the
# enquiry appears on the back-office dashboard automatically.
#
# Production: https://wellnessbackend-8fxe.onrender.com
# Local dev:  http://localhost:8000 (if you're running the backend locally)
NEXT_PUBLIC_WELLNESS_BACKEND_URL=https://wellnessbackend-8fxe.onrender.com
